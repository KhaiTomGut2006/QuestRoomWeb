MONGODB_URI=mongodb://127.0.0.1:27017/quest-room-web
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
NEXT_PUBLIC_ENABLE_DEMO_GUESTS=true
# Required in production for NPC quest image/video uploads.
# Create a public Vercel Blob store and add its read-write token.
BLOB_READ_WRITE_TOKEN=
