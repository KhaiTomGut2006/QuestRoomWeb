MONGODB_URI=mongodb://127.0.0.1:27017/quest-room-web
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
NEXT_PUBLIC_ENABLE_DEMO_GUESTS=true
# Optional: use Cloudflare R2 for direct browser uploads (preferred — CDN-backed, no server relay).
# Copy these from nuutorbot-new's .env. Files land under npc-quests/<discordId>/...
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=
# Optional: use a public Vercel Blob store for direct browser uploads (fallback if R2 not set).
# Without both R2 and this token, NPC quest evidence is stored in MongoDB GridFS.
BLOB_READ_WRITE_TOKEN=
# Use this only when deploying under a path such as https://api.hamsterquest.com/questroom
# NEXT_PUBLIC_BASE_PATH=/questroom
# PORT=3001
